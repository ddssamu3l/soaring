#!/usr/bin/env bash
# The environment gate: no commit (yours or an agent's) lands unless check_all is green.
#
# Interpreter resolution matters here: linked worktrees share this hook (via
# core.hooksPath) but do NOT have their own `.venv` (it's gitignored, lives only in
# the main checkout). So resolve python from the SHARED repo root, not a
# worktree-relative `.venv/bin/python` that won't exist in `../soaring-<agent>`.
# The SCRIPT itself stays worktree-local (cwd = the worktree), so check_all sees the
# agent's staged files, not main's.
set -euo pipefail

# Branch guard: real work goes on a feature branch; main only advances via land.py.
# This blocks a direct `git commit` on main. It does NOT block landing: `git merge`
# fires pre-merge-commit (not this hook), and land.py invokes check_all.py directly.
# Bootstrap / deliberate override: ALLOW_MAIN_COMMIT=1.
BRANCH="$(git rev-parse --abbrev-ref HEAD)"
if [ "$BRANCH" = "main" ] && [ "${ALLOW_MAIN_COMMIT:-}" != "1" ]; then
  echo "pre-commit: refusing a direct commit to main." >&2
  echo "            work on a feature branch:  git checkout -b feature/<taskid>-<slug>" >&2
  echo "            then land it:              python3 cli/land.py feature/<...>" >&2
  echo "            (override for bootstrap:   ALLOW_MAIN_COMMIT=1 git commit ...)" >&2
  exit 1
fi

ROOT="$(cd "$(dirname "$(git rev-parse --git-common-dir)")" && pwd)"
VENV_PY="$ROOT/.venv/bin/python"

if [ ! -x "$VENV_PY" ]; then
  echo "pre-commit: no venv interpreter at $VENV_PY" >&2
  echo "            create it in the main checkout:  uv venv && uv pip install ruff mypy pytest" >&2
  exit 1
fi

exec "$VENV_PY" scripts/check_all.py
